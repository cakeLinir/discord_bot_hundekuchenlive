# ============================================================
# Hundekuchenlive Discord Bot - Git Ignore
# ============================================================

# ------------------------------------------------------------
# Secrets / Environment
# ------------------------------------------------------------
.env
*.env
bot/.env
bot/**/*.env
bot/**/*.env.*

# Token / Secret dumps
*token*
*secret*
*credentials*
*.key
*.pem
*.p12
*.pfx

# Beispiel-Dateien dürfen ins Repo
!.env.example
!bot/.env.example
!*.example.env
!config.example.yaml
!config.example.yml

# ------------------------------------------------------------
# Python cache / build artifacts
# ------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# ------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------
venv/
.venv/
env/
ENV/
bot/venv/
bot/.venv/

# ------------------------------------------------------------
# Python tooling caches
# ------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
bot/logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# SQLite / Bot database
# ------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db3

*.sqlite-wal
*.sqlite-shm
*.sqlite-journal

*.sqlite3-wal
*.sqlite3-shm
*.sqlite3-journal

bot/data/*.sqlite
bot/data/*.sqlite3
bot/data/*.db
bot/data/*.db3

bot/data/*.sqlite-wal
bot/data/*.sqlite-shm
bot/data/*.sqlite-journal

bot/data/*.sqlite3-wal
bot/data/*.sqlite3-shm
bot/data/*.sqlite3-journal

# ------------------------------------------------------------
# Runtime state files
# ------------------------------------------------------------
bot/data/*_state.json
bot/data/sevendtd_panel_state.json
bot/data/satisfactory_panel_state.json
bot/data/ls25_panel_state.json
bot/data/gameserver_panel_state.json
bot/data/selfroles_state.json
bot/data/moderation_state.json
bot/apps/discord_bot/*_state.json
bot/apps/discord_bot/**/*_state.json
bot/data/gameservers.json

# Optional: falls du Runtime-JSONs nicht versionieren willst
bot/data/runtime/
bot/data/cache/
bot/data/tmp/

# Aber data-Ordner im Repo behalten
!bot/data/.gitkeep

# ------------------------------------------------------------
# Local backups / archives
# ------------------------------------------------------------
backup/
backups/
archive/
archives/
tmp/
temp/
*.tmp
*.bak
*.backup
*.old
*.zip
*.7z
*.rar
*.tar
*.tar.gz

# ------------------------------------------------------------
# Uploaded local media / private assets
# ------------------------------------------------------------
bot/apps/discord_bot/img/private/
bot/apps/discord_bot/uploads/
bot/uploads/

# Falls Banner lokal geheim/privat sind, ignorieren:
# bot/apps/discord_bot/img/banner.png

# ------------------------------------------------------------
# Website / unrelated project parts
# ------------------------------------------------------------
website/
PHPMailer/
vendor/
node_modules/
public_html/
htdocs/
www/

# ------------------------------------------------------------
# JavaScript / Node leftovers
# ------------------------------------------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml
node_modules/
.npm/
.pnpm-store/

# ------------------------------------------------------------
# IDE / Editor
# ------------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# FileZilla / FTP clients
# ------------------------------------------------------------
sitemanager.xml
recentservers.xml
filezilla.xml
queue.xml

# ------------------------------------------------------------
# Windows / PowerShell local output
# ------------------------------------------------------------
*.ps1xml
*.pssc
*.psd1.bak
Transcript*.txt

# ------------------------------------------------------------
# Git should keep these
# ------------------------------------------------------------
!.gitignore
!.gitattributes
!README.md
!LICENSE
!requirements.txt
!pyproject.toml
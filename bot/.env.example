# ============================================================
# Hundekuchenlive Discord Bot / JARVIS Migration Example
# ============================================================
# Copy this file to bot/.env on the server.
# Never commit bot/.env.
#
# Complex JARVIS lists should stay in JARVIS' own .env/.env.local.
# This file remains legacy-compatible while the Discord bot is migrated
# from nextcord to discord.py.

# ------------------------------------------------------------
# Discord
# ------------------------------------------------------------
DISCORD_TOKEN=
BOT_OWNER_ID=
BOT_MINIMAL_INTENTS=false
DISCORD_HEARTBEAT_TIMEOUT=45
DISCORD_GUILD_READY_TIMEOUT=5
DISCORD_MAX_MESSAGES=500

# Optional: sync slash commands only to one guild during migration.
# Leave empty for global sync.
DISCORDPY_SYNC_GUILD_ID=

# ------------------------------------------------------------
# Runtime / update control
# ------------------------------------------------------------


BOT_INSTANCE_LOCK_PORT=49291
BOT_ONLY_EXTENSIONS=
BOT_DISABLED_EXTENSIONS=
EVENT_LOOP_LAG_INTERVAL_SECONDS=10
EVENT_LOOP_LAG_WARN_SECONDS=2

# Server scripts can read this value via C:\Bots\HundekuchenBot\entry_module.txt
# legacy:     bot.apps.discord_bot.main
# discord.py: bot.apps.discord_bot.main_discordpy
BOT_ENTRY_MODULE=bot.apps.discord_bot.main

# ------------------------------------------------------------
# JARVIS bridge
# ------------------------------------------------------------
JARVIS_BRIDGE_ENABLED=false
JARVIS_API_BASE_URL=http://127.0.0.1:8000
JARVIS_API_TOKEN=
JARVIS_HEALTH_ENDPOINT=/health
JARVIS_STATUS_ENDPOINT=/modules
JARVIS_TIMEOUT_SECONDS=5

# ------------------------------------------------------------
# Database / retention
# ------------------------------------------------------------
DB_PATH=data/bot_v101.sqlite3
RETENTION_DAYS=30
RETENTION_CLEANUP_INTERVAL_HOURS=24

# ------------------------------------------------------------
# Discord moderation / selfroles
# ------------------------------------------------------------
MOD_ROLE_ID=
MOD_LOG_CHANNEL_ID=
SELFROLE_CHANNEL_ID=

# TODO: migrate these hardcoded role IDs from selfroles_slash.py into config.
SELFROLE_RULES_ROLE_ID=
SELFROLE_TWITCH_ROLE_ID=
SELFROLE_YOUTUBE_ROLE_ID=

# ------------------------------------------------------------
# Gameserver shared channels
# ------------------------------------------------------------
GAMESERVER_HOST=
GAMESERVER_STATUS_CHANNEL_ID=
GAMESERVER_LOG_CHANNEL_ID=
GAMESERVER_PANEL_CHANNEL_ID=

# ------------------------------------------------------------
# Satisfactory
# ------------------------------------------------------------
SATIS_API_URL=
SATIS_API_TOKEN=
SATIS_DASHBOARD_URL=
SATIS_BANNER_URL=
SATIS_HOST=
SATIS_PORT=
SATIS_PANEL_CHANNEL_ID=
SATIS_LOG_CHANNEL_ID=

# ------------------------------------------------------------
# 7 Days to Die Integration
# ------------------------------------------------------------
SEVENDTD_API_BASE_URL=
SEVENDTD_READ_TOKEN_NAME=
SEVENDTD_READ_TOKEN_SECRET=
SEVENDTD_ADMIN_TOKEN_NAME=
SEVENDTD_ADMIN_TOKEN_SECRET=
SEVENDTD_TOKEN_NAME_HEADER=
SEVENDTD_TOKEN_SECRET_HEADER=
SEVENDTD_COMMAND_ENDPOINT=
SEVENDTD_COMMAND_BODY_KEY=
SEVENDTD_PUBLIC_HOST=
SEVENDTD_GAME_PORT=
SEVENDTD_MAX_PLAYERS=
SEVENDTD_WORLD_NAME=
SEVENDTD_SAVE_NAME=
SEVENDTD_PANEL_CHANNEL_ID=
SEVENDTD_EVENT_MONITOR_ENABLED=false
SEVENDTD_EVENT_CHANNEL_ID=
SEVENDTD_LOG_SSE_ENDPOINT=
SEVENDTD_LOG_TOKEN_KIND=
SEVENDTD_EVENT_FORWARD_CHAT=false
SEVENDTD_EVENT_RAW_DEBUG=false

# ------------------------------------------------------------
# LS25 Panel
# ------------------------------------------------------------
LS25_ENABLED=false
LS25_PANEL_CHANNEL_ID=
LS25_LOG_CHANNEL_ID=
LS25_HOST=
LS25_GAME_PORT=
LS25_WEB_HTTP_PORT=
LS25_WEB_HTTPS_PORT=
LS25_DASHBOARD_URL=
LS25_HEALTH_URL=
LS25_SERVER_NAME=
LS25_MAX_PLAYERS=

# ------------------------------------------------------------
# Optional / future legacy integrations
# ------------------------------------------------------------
RAWG_API_KEY=
NEWS_GAMES_CHANNEL_ID=
NEWS_IG_CHANNEL_ID=
NEWS_MANUAL_CHANNEL_ID=
NEWS_LIVE_CHANNEL_ID=

TWITCH_BOT_NICK=
TWITCH_BOT_TOKEN=
TWITCH_CHANNEL=


JARVIS_BACKEND_URL=http://127.0.0.1:8000
JARVIS_AGENT_ID=justin-main-pc